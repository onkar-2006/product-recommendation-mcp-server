# ==========================================
# E-Commerce MCP Server Configuration Template
# Rename this file to '.env' and modify settings
# ==========================================

# MCP Server Transport Settings
TRANSPORT=stdio              # 'stdio' for local LLM assistants, 'sse' for cloud/remote hosting
HOST=0.0.0.0                 # Bind address for SSE HTTP server
PORT=8000                    # Bind port for SSE HTTP server
API_KEY=                     # Optional secure API token. If set, SSE requests require Bearer token.

# Browser Scraper Controls
HEADLESS=true                # Run browser headless (always true in Docker/Production)
TIMEOUT_MS=30000             # Max page navigation and load timeout in milliseconds
MAX_CONCURRENT_CONTEXTS=5    # Max concurrent browser tabs (caps RAM usage in containers)

# Rotating Proxies (Highly recommended to bypass e-commerce blockages in cloud datacenters)
# PROXY_SERVER=http://myproxyprovider.com:8000
# PROXY_USERNAME=my_username
# PROXY_PASSWORD=my_password

# Caching & Databases
CACHE_ENABLED=true
SQLITE_DB_PATH=data/mcp_cache.db
CACHE_TTL_SEARCH_SECONDS=600     # 10 minutes search cache lifetime
CACHE_TTL_DETAILS_SECONDS=86400   # 24 hours product specifications cache lifetime

# Logger Level
LOG_LEVEL=INFO
LOG_FILE=logs/mcp.log
